FROM golang:1.22-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /confidential-ai ./cmd/server/

# ---

# Use the CUDA *devel* image (not runtime) so that vLLM 0.21.0's
# flashinfer-python dependency can JIT-compile its sampling kernels
# at first inference. flashinfer ships a prebuilt wheel but lazily
# generates additional kernel variants via nvcc at runtime, and those
# need:
#   - nvcc                          (cuda-nvcc-12-6)
#   - curand.h, cublas.h, ...        (libcurand-dev, libcublas-dev, ...)
#   - cudart development headers     (cuda-cudart-dev-12-6)
# rather than play whack-a-mole with -dev packages on top of the
# runtime image, switching to -devel pulls the full CUDA 12.6 toolkit
# (matches our runtime version) in one go.
# Cost: image ~3 GB larger; unavoidable until flashinfer ships fully
# precompiled kernels for the variants vLLM 0.21.0 enables by default
# (FlashInfer top-k/top-p sampler).
FROM nvidia/cuda:12.6.3-devel-ubuntu24.04

# vLLM v0.22.1 — adds `--performance-mode`, Qwen3-Next MTP speculative
# decoding (`{"method":"qwen3_next_mtp"}`), configurable CUDA-graph
# capture size, and expanded mamba-ssm-cache-dtype handling for hybrid
# (Gated DeltaNet) models. v0.21.0 introduced Qwen3.5/3.6 GDN support;
# v0.20.0 introduced the Gemma 4 reasoning + tool-call parsers.
# Release: https://github.com/vllm-project/vllm/releases/tag/v0.22.1
# Recipe:  https://docs.vllm.ai/projects/recipes/en/latest/Qwen/Qwen3.5.html
#
# CUDA pinning: vLLM publishes two x86_64 GPU wheels per release on
# GitHub: the default (built against CUDA 13, references libcudart.so.13)
# and an explicit `+cu129` wheel (built against CUDA 12.9, references
# libcudart.so.12). Our base image ships the CUDA 12.6 runtime and we
# want to stay on CUDA 12.x, so we install the +cu129 wheel directly
# from the GitHub release and pair it with the cu129 PyTorch backend
# (binary-compatible with the cu126 base — torch ships its own bundled
# libcudart.so.12).
# Note: v0.22.x wheels moved their manylinux tag back from `_2_34`
# (v0.21.0) to `_2_28`. Ubuntu 24.04 ships glibc 2.39, which satisfies
# either. Installing plain `vllm==0.22.1` resolves to the CUDA 13
# default wheel and crashes at import with
# `ImportError: libcudart.so.13: cannot open shared object file`.

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv python3.12-dev python3-pip ca-certificates curl \
    gcc libc6-dev && \
    rm -rf /var/lib/apt/lists/*

ENV UV_BREAK_SYSTEM_PACKAGES=1

RUN pip3 install --no-cache-dir --break-system-packages uv && \
    uv pip install --system --torch-backend=cu129 \
      "https://github.com/vllm-project/vllm/releases/download/v0.22.1/vllm-0.22.1+cu129-cp38-abi3-manylinux_2_28_x86_64.whl"

# Bake the official Gemma 4 chat template into the image so the
# manager can reference it by short name (--chat-template gemma4
# resolves here). Pinned to the exact vLLM release tag for
# reproducibility.
RUN mkdir -p /opt/vllm-templates && \
    curl -fsSL -o /opt/vllm-templates/tool_chat_template_gemma4.jinja \
      https://raw.githubusercontent.com/vllm-project/vllm/v0.22.1/examples/tool_chat_template_gemma4.jinja

COPY --from=builder /confidential-ai /usr/local/bin/confidential-ai
COPY scripts/entrypoint.sh /opt/confidential-ai/entrypoint.sh
RUN chmod +x /opt/confidential-ai/entrypoint.sh

# Model disks: GCP persistent disks are auto-mounted at /mnt/model-* by
# systemd. Bind-mount the whole /mnt into the container so the models
# manager can discover and load any available model on-demand.
LABEL ai.privasys.volume="/mnt:/models:ro"

# GPU passthrough: this image declares the NVIDIA device nodes it needs, so
# the manager passes them through (and enables CDI driver injection) on any
# deploy without per-deploy configuration, mirroring the volume label above.
LABEL ai.privasys.devices="/dev/nvidia0,/dev/nvidiactl,/dev/nvidia-uvm,/dev/nvidia-uvm-tools"

# Dynamic model loading mode: Go proxy starts immediately, vLLM on-demand.
ENV MODELS_DIR=/models
# Pin the version reported in reproducibility metadata to the wheel
# actually installed above. entrypoint.sh and config.go carry the same
# value as a fallback, but this env is the source of truth — the
# per-response `reproducibility.vllm_version` field must agree with
# the wheel. (The running server is always correct — vLLM's
# system_fingerprint comes from the wheel itself — but our attestation
# metadata must match it.)
ENV VLLM_VERSION=0.22.1
ENV CUDA_VERSION=12.6.3

# Disable DeepGEMM FP8 JIT path. vLLM v0.21.0+ ships bundled DeepGEMM
# kernels that JIT-compile via nvcc at first inference for native FP8
# models (e.g. Qwen3.6-35B-A3B-FP8) on Hopper. With the CUDA 12.6
# devel toolkit baked in, the JIT compile aborts with:
#   "Assertion error ... false and 'NVCC compilation failed'"
#   (vllm/utils/deep_gemm.py:295 fp8_gemm_nt -> third_party/deep_gemm).
# Until we ship a vetted DeepGEMM build (or vLLM ships prebuilt FP8
# kernels for the variants it enables by default), force vLLM to use
# its CUTLASS/Triton FP8 backends instead, which work out of the box.
# Cost: ~10–20% throughput on FP8 MoE; correctness unchanged.
ENV VLLM_USE_DEEP_GEMM=0
ENV VLLM_MOE_USE_DEEP_GEMM=0

EXPOSE 8000 8080

ENTRYPOINT ["/opt/confidential-ai/entrypoint.sh"]
