FROM golang:1.22-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /confidential-ai ./cmd/server/

# ---

FROM nvidia/cuda:12.6.3-runtime-ubuntu24.04

# vLLM v0.21.0 — adds Qwen3.5/Qwen3.6 Gated DeltaNet support, Gemma4
# MoE/tool-parser fixes, MTP for Gemma4, and FlashInfer top-k/top-p
# sampler enabled by default. v0.20.0 first introduced Gemma 4
# reasoning + tool-call parsers (`--reasoning-parser gemma4`,
# `--tool-call-parser gemma4`).
# Release: https://github.com/vllm-project/vllm/releases/tag/v0.21.0
# Recipe:  https://docs.vllm.ai/projects/recipes/en/latest/Google/Gemma4.html
#
# CUDA pinning: vLLM publishes two x86_64 GPU wheels for v0.21.0 on
# GitHub: the default (built against CUDA 13, references libcudart.so.13)
# and an explicit `+cu129` wheel (built against CUDA 12.9, references
# libcudart.so.12). Our base image ships the CUDA 12.6 runtime and we
# want to stay on CUDA 12.x, so we install the +cu129 wheel directly
# from the GitHub release and pair it with the cu129 PyTorch backend
# (binary-compatible with the cu126 base — torch ships its own bundled
# libcudart.so.12).
# Note: v0.21.0 wheels bumped their manylinux tag from `_2_31` (in
# v0.20.1) to `_2_34`. Ubuntu 24.04 ships glibc 2.39, which satisfies it.
# Installing plain `vllm==0.21.0` resolves to the CUDA 13 default
# wheel and crashes at import with
# `ImportError: libcudart.so.13: cannot open shared object file`.

# cuda-nvcc-12-6 is required at *runtime* because vLLM 0.21.0 pulls in
# flashinfer-python 0.6.8, which JIT-compiles sampling kernels via nvcc
# on first inference (the prebuilt wheel does not ship every kernel
# variant). Without nvcc the engine crashes with
# `Ninja build failed: /usr/local/cuda/bin/nvcc: not found`.
# The `cuda-nvcc-12-6` metapackage matches the 12.6 runtime already
# present in the base image; adds ~1.5 GB.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv python3.12-dev python3-pip ca-certificates curl \
    gcc libc6-dev cuda-nvcc-12-6 && \
    rm -rf /var/lib/apt/lists/*

ENV UV_BREAK_SYSTEM_PACKAGES=1

RUN pip3 install --no-cache-dir --break-system-packages uv && \
    uv pip install --system --torch-backend=cu129 \
      "https://github.com/vllm-project/vllm/releases/download/v0.21.0/vllm-0.21.0+cu129-cp38-abi3-manylinux_2_34_x86_64.whl"

# Bake the official Gemma 4 chat template into the image so the
# manager can reference it by short name (--chat-template gemma4
# resolves here). Pinned to the exact vLLM release tag for
# reproducibility.
RUN mkdir -p /opt/vllm-templates && \
    curl -fsSL -o /opt/vllm-templates/tool_chat_template_gemma4.jinja \
      https://raw.githubusercontent.com/vllm-project/vllm/v0.21.0/examples/tool_chat_template_gemma4.jinja

COPY --from=builder /confidential-ai /usr/local/bin/confidential-ai
COPY scripts/entrypoint.sh /opt/confidential-ai/entrypoint.sh
RUN chmod +x /opt/confidential-ai/entrypoint.sh

# Model disks: GCP persistent disks are auto-mounted at /mnt/model-* by
# systemd. Bind-mount the whole /mnt into the container so the models
# manager can discover and load any available model on-demand.
LABEL ai.privasys.volume="/mnt:/models:ro"

# Dynamic model loading mode: Go proxy starts immediately, vLLM on-demand.
ENV MODELS_DIR=/models

EXPOSE 8000 8080

ENTRYPOINT ["/opt/confidential-ai/entrypoint.sh"]
