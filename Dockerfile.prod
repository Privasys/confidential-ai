FROM golang:1.22-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /confidential-ai ./cmd/server/

# ---

FROM nvidia/cuda:12.6.3-runtime-ubuntu24.04

# vLLM nightly: pre-built wheels from main branch, required for Gemma 4
# (gemma4 architecture) and other recent model support not yet in a release.
# Wheels are published for every commit on main at https://wheels.vllm.ai/nightly

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv python3-pip ca-certificates curl && \
    rm -rf /var/lib/apt/lists/*

ENV UV_BREAK_SYSTEM_PACKAGES=1

RUN pip3 install --no-cache-dir --break-system-packages uv && \
    uv pip install --system --torch-backend=cu126 vllm \
    --extra-index-url https://wheels.vllm.ai/nightly && \
    uv pip install --system --upgrade transformers

COPY --from=builder /confidential-ai /usr/local/bin/confidential-ai
COPY scripts/entrypoint.sh /opt/confidential-ai/entrypoint.sh
RUN chmod +x /opt/confidential-ai/entrypoint.sh

EXPOSE 8000 8080

ENTRYPOINT ["/opt/confidential-ai/entrypoint.sh"]
