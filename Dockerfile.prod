FROM golang:1.22-bookworm AS builder

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags='-s -w' -o /confidential-ai ./cmd/server/

# ---

FROM nvidia/cuda:12.6.3-runtime-ubuntu24.04

# vLLM v0.20.1 — patch on top of v0.20.0 (DeepSeek V4 stabilisation +
# bug fixes). v0.20.0 ships first-class Gemma 4 reasoning + tool-call
# parsers (`--reasoning-parser gemma4`, `--tool-call-parser gemma4`),
# so we no longer have to coax the model into emitting <think> tags
# from the system prompt. v0.20 requires `transformers>=5` and CUDA
# 12.x is supported via the cu126 torch backend.
# Release: https://github.com/vllm-project/vllm/releases/tag/v0.20.1
# Recipe:  https://docs.vllm.ai/projects/recipes/en/latest/Google/Gemma4.html

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.12 python3.12-venv python3.12-dev python3-pip ca-certificates curl \
    gcc libc6-dev && \
    rm -rf /var/lib/apt/lists/*

ENV UV_BREAK_SYSTEM_PACKAGES=1

RUN pip3 install --no-cache-dir --break-system-packages uv && \
    uv pip install --system --torch-backend=cu126 vllm==0.20.1

# Bake the official Gemma 4 chat template into the image so the
# manager can reference it by short name (--chat-template gemma4
# resolves here). Pinned to the exact vLLM release tag for
# reproducibility.
RUN mkdir -p /opt/vllm-templates && \
    curl -fsSL -o /opt/vllm-templates/tool_chat_template_gemma4.jinja \
      https://raw.githubusercontent.com/vllm-project/vllm/v0.20.1/examples/tool_chat_template_gemma4.jinja

COPY --from=builder /confidential-ai /usr/local/bin/confidential-ai
COPY scripts/entrypoint.sh /opt/confidential-ai/entrypoint.sh
RUN chmod +x /opt/confidential-ai/entrypoint.sh

# Model disks: GCP persistent disks are auto-mounted at /mnt/model-* by
# systemd. Bind-mount the whole /mnt into the container so the models
# manager can discover and load any available model on-demand.
LABEL ai.privasys.volume="/mnt:/models:ro"

# Dynamic model loading mode: Go proxy starts immediately, vLLM on-demand.
ENV MODELS_DIR=/models

EXPOSE 8000 8080

ENTRYPOINT ["/opt/confidential-ai/entrypoint.sh"]
